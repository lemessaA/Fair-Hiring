# Copy to .env.local for local dev. On Vercel, set the same variable in
# Project → Settings → Environment Variables (all relevant environments).

# Base URL of the FastAPI app (no trailing slash). Next rewrites /api/* → this host.
# Local default in next.config is http://127.0.0.1:8000 if unset.
# Production: point at your FastAPI deployment (same value you may set as FRONTEND_URL on the API for CORS).
# BACKEND_URL=https://fair-hireing.fastapicloud.dev

# Optional: comma-separated hostnames for Turbopack when you open the dev server by LAN IP
# NEXT_ALLOWED_DEV_ORIGINS=192.168.1.10
